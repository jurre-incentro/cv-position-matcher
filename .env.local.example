NEXT_PUBLIC_APP_URL=http://localhost:3000

# These names are used by the app. If Vercel/Supabase created NEXT_PUBLIC_* variants,
# you can copy those values into these local aliases.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Vercel/Supabase integration names. The app can also read these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional Vercel/Supabase integration names when the integration is prefixed.
STORAGE_CV_SUPABASE_URL=
NEXT_PUBLIC_STORAGE_CV_SUPABASE_ANON_KEY=
NEXT_PUBLIC_STORAGE_CV_SUPABASE_PUBLISHABLE_KEY=
STORAGE_CV_SUPABASE_SERVICE_ROLE_KEY=
STORAGE_CV_SUPABASE_SECRET_KEY=

RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESULT_EMAIL_FROM=scans@example.com
RESULT_EMAIL_TO=you@example.com

GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
